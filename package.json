{
  "name": "ui-contract-deploy",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "homepage": "https://nasirchaingpt.github.io/Deploy_Contracts/",
  "scripts": {
    "compile": "hardhat compile",
    "deploy": "npm run build && node scripts/verify-dist-for-pages.mjs && gh-pages -d dist --dotfiles",
    "prebuild": "hardhat compile && node scripts/copy-artifact.mjs",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "ethers": "^6.13.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@openzeppelin/contracts": "^4.9.6",
    "@openzeppelin/contracts-upgradeable": "^4.9.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "gh-pages": "^6.3.0",
    "hardhat": "^2.22.17",
    "typescript": "~5.6.3",
    "vite": "^5.4.11"
  }
}
